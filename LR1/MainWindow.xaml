<Window x:Class="LR1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:LR1"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        
        <StackPanel Grid.Column="0" Margin="0,0,10,0">
            <TextBlock x:Name="WelcomeTextBlock" 
                       FontSize="16" 
                       FontWeight="Bold" 
                       TextWrapping="Wrap" 
                       Margin="0,0,0,20"/>
            <Button Content="Exit"
                    Padding="5"
                    Click="LogoutButton_Click"
                    Margin="30,10"
                    Background="#0078D7" 
                    Foreground="White" 
                    FontFamily="Gabriola"
                    FontSize="16"
                    FontWeight="DemiBold"/>
        </StackPanel>
        <GroupBox x:Name="AdminPanel" 
                  Grid.Column="1" 
                  Header="Admin panel" 
                  Visibility="Collapsed">
            <Grid >
         
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <StackPanel Orientation="Horizontal"
                            Grid.Row="0"
                            Margin="10">
                    <Button x:Name="ShowUsersListButton"
                            Content="Users list"
                            Margin="5"
                            Padding="5,1"
                            Background="#0078D7" 
                            Foreground="White" 
                            FontFamily="Gabriola"
                            FontSize="16"
                            Click="ShowUsersListButton_Click"/>
                    <Button x:Name="ShowActionsButton"
                            Content="Actions"
                            Margin="5"
                            Padding="5,1"
                            Background="#0078D7" 
                            Foreground="White" 
                            FontFamily="Gabriola"
                            FontSize="16"
                            Click="ShowActionsButton_Click"/>
                </StackPanel>

                <ListBox x:Name="UsersListBox"
                             Grid.Row="1"
                             Margin="0,10"
                             Visibility="Collapsed">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding Name}" FontWeight="Bold" Width="100"/>
                                <TextBlock Text="{Binding Role}" Width="80"/>
                                <TextBlock Text="Status: "/>
                                <TextBlock Text="{Binding Status}"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
                <DataGrid x:Name="AdminGrid" 
                          AutoGenerateColumns="False" 
                          CanUserAddRows="False"
                          Visibility="Collapsed"
                          Grid.Row="1">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Login" 
                                            Binding="{Binding Name}" 
                                            Width="*"/>
                        <DataGridTextColumn Header="Status" 
                                            Binding="{Binding Status}" 
                                            Width="100"/>
                        <DataGridTemplateColumn Header="Action" 
                                                Width="120">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="Reset the status" Click="ResetStatus_Click" Background="Orange"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <Button Content="Add meneger" 
                        Grid.Row="2" 
                        Padding="5" 
                        HorizontalAlignment="Right" 
                        Margin="30,10"
                        Background="#0078D7" 
                        Foreground="White" 
                        FontFamily="Gabriola"
                        FontSize="16"
                        Click="AddManagerButton_Click"/>
            </Grid>
        </GroupBox>

        <GroupBox x:Name="ManagerPanel"
                  Grid.Column="1"
                  Margin="10"
                  Visibility="Collapsed">
            <DataGrid x:Name="ManagerGrid"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Login"
                                        Binding="{Binding Name}"
                                        FontFamily="Arial"
                                        FontSize="16"
                                        Width="*"
                                        />
                    <DataGridTemplateColumn Header="Actions"
                                            Width="180">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <Button x:Name="ApprovedButton" 
                                            Content="Approve" 
                                            Background="Green" 
                                            Foreground="White" 
                                            FontFamily="Arial Black"
                                            FontSize="16"
                                            FontWeight="Bold"
                                            Click="Approve_Click" 
                                            Margin="10,5" 
                                            Padding="5"/>
                                    <Button x:Name="RejectedButton" 
                                            Content="Reject" 
                                            Background="Red" 
                                            Foreground="White" 
                                            FontFamily="Arial Black"
                                            FontSize="16"
                                            FontWeight="Bold"
                                            Click="Reject_Click" 
                                            Margin="5" 
                                            Padding="1"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                        
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
                
            </DataGrid>
            
        </GroupBox>

        <GroupBox x:Name="ClientPanel"
                  Visibility="Collapsed"
                  Grid.Column="1"
                  Margin="10"
                  Header="A Client`s account">
            <TabControl>
                <TabItem Header="Banks">
                    <ListBox x:Name="BanksListBox"
                             Margin="10">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="5">
                                    <TextBlock Text="{Binding Name}" FontSize="16" FontWeight="Bold"/>
                                    <TextBlock Text="{Binding BankId}" Foreground="Gray"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                        
                    </ListBox>
                </TabItem>
                <TabItem Header="My accounts">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <DataGrid x:Name="ClientAccountsGrid" 
                                  AutoGenerateColumns="False" 
                                  CanUserAddRows="False">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Bank" 
                                                    Binding="{Binding BankName}" 
                                                    Width="100"/>
                                <DataGridTextColumn Header="Number of an account" 
                                                    Binding="{Binding Number}" 
                                                    Width="*"/>
                                <DataGridTextColumn Header="Balance" 
                                                    Binding="{Binding Balance}" 
                                                    Width="80"/>
                                <DataGridCheckBoxColumn Header="Blocked" 
                                                        Binding="{Binding IsBlocked}" 
                                                        IsReadOnly="True"/>
                            </DataGrid.Columns>
                        </DataGrid>
                        <StackPanel Grid.Row="1" 
                                    Orientation="Horizontal" 
                                    HorizontalAlignment="Right">
                            <Button Content="Open an account" 
                                    Margin="5" 
                                    Padding="10,5" 
                                    Click="OpenAccount_Click"/>
                            <Button Content="Deposite" 
                                    Margin="5" 
                                    Padding="10,5" 
                                    Click="DepositeAccount_Click"/>
                            <Button Content="Transfer" 
                                    Margin="5" 
                                    Padding="10,5" 
                                    Click="Transfer_Click"/>
                            <Button Content="History" 
                                    Margin="5" 
                                    Padding="10,5" 
                                    Click="History_Click"/>
                        </StackPanel>
                    </Grid>
                </TabItem>
                <TabItem Header="My deposits">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <DataGrid x:Name="ClientDepositsGrid" 
                                  AutoGenerateColumns="False" 
                                  CanUserAddRows="False">   
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Bank" 
                                                    Binding="{Binding BankName}" 
                                                    Width="100"/>
                                <DataGridTextColumn Header="Number of a deposit" 
                                                    Binding="{Binding Number}" 
                                                    Width="*"/>
                                <DataGridTextColumn Header="Balance" 
                                                    Binding="{Binding Balance}" 
                                                    Width="80"/>
                                <DataGridTextColumn Header="Procent" 
                                                    Binding="{Binding InterestRate}" 
                                                    Width="80"/>
                                <DataGridTextColumn Header="Term (mo)" 
                                                    Binding="{Binding TermMonths}" 
                                                    Width="80"/>
                                <DataGridTextColumn Header="Finish Date" 
                                                    Binding="{Binding EndDate, StringFormat=\{0:HH:mm:ss\}}" 
                                                    Width="100"/>
                                <DataGridCheckBoxColumn Header="Blocked" 
                                                    Binding="{Binding IsBlocked}" 
                                                    IsReadOnly="True"/>
                                <DataGridTextColumn Header="Accrued Interest" 
                                                    Binding="{Binding CurrentInterest, StringFormat=\{0:C\}}" 
                                                    Width="120" 
                                                    Foreground="Green" 
                                                    FontWeight="Bold"/>

                            </DataGrid.Columns>
                        </DataGrid>

                        <StackPanel Grid.Row="1" 
                                    Orientation="Horizontal" 
                                    HorizontalAlignment="Right">
                            <Button Content="Open a deposite" 
                                    Margin="5" 
                                    Padding="10,5" 
                                    Click="OpenDeposite_Click"/>
                            <Button Content="Deposite" 
                                    Margin="5" 
                                    Padding="10,5" 
                                    Click="DepositeDeposite_Click"/>
                            <Button Content="Transfer" 
                                    Margin="5" 
                                    Padding="10,5" 
                                    Click="TransferDeposit_Click"/>
                        </StackPanel>

                    </Grid>
                </TabItem>
            </TabControl>
            
        </GroupBox>
    </Grid>
</Window>
