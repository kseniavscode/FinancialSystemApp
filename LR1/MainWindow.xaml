<Window x:Class="LR1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:LR1"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0" Margin="0,0,10,0">
            <TextBlock x:Name="WelcomeTextBlock" 
                       FontSize="16" 
                       FontWeight="Bold" 
                       TextWrapping="Wrap" 
                       Margin="0,0,0,20"/>
            <Button Content="Exit"
                    Padding="5"
                    Click="LogoutButton_Click"
                    Margin="30,10"
                    Background="#0078D7" 
                    Foreground="White" 
                    FontFamily="Gabriola"
                    FontSize="16"
                    FontWeight="DemiBold"/>
        </StackPanel>
        <GroupBox x:Name="AdminPanel" 
          Grid.Column="1" 
          Header="Admin Control Center" 
          Visibility="Collapsed"
          Margin="10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- ОДИН общий TabControl для всех трех вкладок -->
                <TabControl Grid.Row="0" Background="White" BorderBrush="#0078D7">

                    <!-- Вкладка 1: Просмотр -->
                    <TabItem Header="Users Overview">
                        <ListBox x:Name="UsersListBox" Margin="5">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="#EEE" BorderThickness="0,0,0,1" Padding="5">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding Name}" FontWeight="Bold" Width="120"/>
                                            <TextBlock Text="{Binding Role}" Width="100" Foreground="Gray"/>
                                            <TextBlock Text="Status: "/>
                                            <TextBlock Text="{Binding Status}" FontWeight="SemiBold">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Status}" Value="Approved">
                                                                <Setter Property="Foreground" Value="Green"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Status}" Value="Rejected">
                                                                <Setter Property="Foreground" Value="Red"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </TabItem>

                    <!-- Вкладка 2: Управление статусами -->
                    <TabItem Header="Status Actions">
                        <DataGrid x:Name="AdminGrid" 
                          AutoGenerateColumns="False" 
                          CanUserAddRows="False" 
                          IsReadOnly="True"
                          Margin="5">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="User Name" Binding="{Binding Name}" Width="*"/>
                                <DataGridTextColumn Header="Current Status" Binding="{Binding Status}" Width="120"/>
                                <DataGridTemplateColumn Header="Action" Width="150">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Content="Reset to Pending" 
                                            Click="ResetStatus_Click" 
                                            Background="Orange" 
                                            Margin="2"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </TabItem>

                    <!-- Вкладка 3: Транзакции -->
                    <TabItem Header="System Transactions">
                        <DataGrid x:Name="AllTransactionsGrid" 
                          AutoGenerateColumns="False" 
                          IsReadOnly="True" 
                          Margin="5">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Time" Binding="{Binding DateTime, StringFormat={}{0:HH:mm dd.MM}}" Width="90"/>
                                <DataGridTextColumn Header="Sum" Binding="{Binding Amount, StringFormat={}{0:F2}}" Width="80"/>
                                <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="*"/>
                                <DataGridTemplateColumn Header="Rollback" Width="110">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Grid>
                                                <!-- Кнопка без конвертера -->
                                                <Button x:Name="RollbackBtn" 
                                                Content="Rollback" 
                                                Click="RollbackTransaction_Click"
                                                Background="LightSalmon"
                                                Padding="5,2"/>
                                                <TextBlock x:Name="CancelledTxt" 
                                                   Text="CANCELLED" 
                                                   Foreground="Red" 
                                                   FontWeight="Bold" 
                                                   HorizontalAlignment="Center" 
                                                   Visibility="Collapsed"/>
                                            </Grid>
                                            <DataTemplate.Triggers>
                                                <DataTrigger Binding="{Binding IsCancelled}" Value="True">
                                                    <Setter TargetName="RollbackBtn" Property="Visibility" Value="Collapsed"/>
                                                    <Setter TargetName="CancelledTxt" Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </DataTemplate.Triggers>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </TabItem>
                </TabControl>

                <!-- Кнопка добавления менеджера вынесена в нижний ряд сетки -->
                <Button Content="Add New Manager" 
                Grid.Row="1" 
                Padding="10,5" 
                HorizontalAlignment="Right" 
                Margin="10"
                Background="#0078D7" 
                Foreground="White" 
                FontFamily="Gabriola"
                FontSize="18"
                Click="AddManagerButton_Click"/>
            </Grid>
        </GroupBox>



        <GroupBox x:Name="ManagerPanel"
                  Grid.Column="1"
                  Margin="10"
                  Visibility="Collapsed">
            <Grid>
                <TabControl>
                    <TabItem Header="Pending Users">
                        <DataGrid x:Name="PendingUsersGrid" AutoGenerateColumns="False" IsReadOnly="True" Margin="5" CanUserAddRows="False">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Name" 
                                                    Binding="{Binding Name}" 
                                                    Width="*"/>
                                <DataGridTextColumn Header="Role" 
                                                    Binding="{Binding Role}" 
                                                    Width="*"/>

                                <DataGridTemplateColumn Header="Actions" 
                                                        Width="150">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" 
                                                        HorizontalAlignment="Center">
                                                <Button Content="✓" 
                                                        Foreground="Green" 
                                                        FontWeight="Bold" 
                                                        Width="30" 
                                                        Margin="2" 
                                                        Click="ApproveUserInline_Click" 
                                                        ToolTip="Approve"/>
                                                <Button Content="✗" 
                                                        Foreground="Red" 
                                                        FontWeight="Bold" 
                                                        Width="30" 
                                                        Margin="2" 
                                                        Click="RejectUserInline_Click" 
                                                        ToolTip="Reject"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </TabItem>
                    
                    <TabItem Header="Salary Requests">
                        <DataGrid x:Name="PendingSalaryRequestsGrid" 
                                  AutoGenerateColumns="False" 
                                  IsReadOnly="True" 
                                  Margin="5" 
                                  CanUserAddRows="False">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="User" 
                                                    Binding="{Binding Name}" 
                                                    Width="*"/>
                                <DataGridTextColumn Header="Enterprise" 
                                                    Binding="{Binding Name}" 
                                                    Width="*"/>

      
                                <DataGridTemplateColumn Header="Actions" 
                                                        Width="150">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" 
                                                        HorizontalAlignment="Center">
                                                <Button Content="✓" 
                                                        Foreground="Green" 
                                                        FontWeight="Bold" 
                                                        Width="30" 
                                                        Margin="2" 
                                                        Click="ApproveSalaryInline_Click" 
                                                        ToolTip="Approve"/>
                                                <Button Content="✗" 
                                                        Foreground="Red" 
                                                        FontWeight="Bold" 
                                                        Width="30" 
                                                        Margin="2" 
                                                        Click="RejectSalaryInline_Click" 
                                                        ToolTip="Reject"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </TabItem>
                    
                    <TabItem Header="Enterprises &amp; Staff">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="200"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <ListBox x:Name="ManagerEnterprisesListBox" 
                                     Margin="5" 
                                     SelectionChanged="ManagerEnterprisesListBox_SelectionChanged"
                                     DisplayMemberPath="Name"/>
                            <StackPanel Grid.Column="1" 
                                        Margin="5">
                                <TextBlock Text="Employees of selected enterprise:" 
                                           FontWeight="Bold" 
                                           Margin="0,0,0,5"/>
                                <DataGrid x:Name="EnterpriseEmployeesGrid" 
                                          AutoGenerateColumns="False" 
                                          IsReadOnly="True" 
                                          Height="200" 
                                          CanUserAddRows="False">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Name" 
                                                            Binding="{Binding Name}" 
                                                            Width="*"/>
                                        <DataGridTemplateColumn Width="100">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <Button Content="Remove" 
                                                            Click="RemoveEmployee_Click" 
                                                            Background="#FFECEC"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                    </DataGrid.Columns>
                                </DataGrid>
                                <Button Content="Add Employee (Select from List)" 
                                        Margin="0,10,0,0" 
                                        Click="AddEmployeeToEnterprise_Click"/>
                            </StackPanel>
                        </Grid>
                    </TabItem>
                    <!-- 4. НОВОЕ: Блокировка счетов -->
                    <TabItem Header="Accounts Control">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <GroupBox Header="Checking Accounts" Grid.Row="0">
                                <DataGrid x:Name="ManagerAllAccountsGrid" AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="User" 
                                                            Binding="{Binding OwnerId}" 
                                                            Width="50"/>
                                        <DataGridTextColumn Header="Number" 
                                                            Binding="{Binding Number}" 
                                                            Width="*"/>
                                        <DataGridCheckBoxColumn Header="Blocked" 
                                                                Binding="{Binding IsBlocked}"/>
                                        <DataGridTemplateColumn Width="100">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <Button Content="Toggle Block" 
                                                            Click="ToggleBlockAccount_Click"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </GroupBox>
                            <GroupBox Header="Deposits" 
                                      Grid.Row="1">
                                <DataGrid x:Name="ManagerAllDepositsGrid" 
                                          AutoGenerateColumns="False" 
                                          IsReadOnly="True" 
                                          CanUserAddRows="False">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="User" 
                                                            Binding="{Binding OwnerId}" 
                                                            Width="50"/>
                                        <DataGridTextColumn Header="Number" 
                                                            Binding="{Binding Number}" 
                                                            Width="*"/>
                                        <DataGridCheckBoxColumn Header="Blocked" 
                                                                Binding="{Binding IsBlocked}"/>
                                        <DataGridTemplateColumn Width="100">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <Button Content="Toggle Block" 
                                                            Click="ToggleBlockDeposit_Click"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </GroupBox>
                        </Grid>
                    </TabItem>

                    <TabItem Header="Transaction History">
                        <DataGrid x:Name="ManagerHistoryGrid" 
                                  AutoGenerateColumns="False" 
                                  IsReadOnly="True" 
                                  Margin="5">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Date" 
                                                    Binding="{Binding DateTime}" 
                                                    Width="120"/>
                                <DataGridTextColumn Header="Sum" 
                                                    Binding="{Binding Amount}" 
                                                    Width="80"/>
                                <DataGridTextColumn Header="Info" 
                                                    Binding="{Binding Description}" 
                                                    Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </TabItem>
                </TabControl>
            </Grid>


        </GroupBox>

        <GroupBox x:Name="ClientPanel"
                  Visibility="Collapsed"
                  Grid.Column="1"
                  Margin="10"
                  Header="A Client`s account">
            <TabControl>
                <TabItem Header="Banks">
                    <ListBox x:Name="BanksListBox"
                             Margin="10">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="5">
                                    <TextBlock Text="{Binding Name}" FontSize="16" FontWeight="Bold"/>
                                    <TextBlock Text="{Binding BankId}" Foreground="Gray"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>

                    </ListBox>
                </TabItem>
                <TabItem Header="My accounts">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <DataGrid x:Name="ClientAccountsGrid" 
                                  AutoGenerateColumns="False" 
                                  CanUserAddRows="False">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Bank" 
                                                    Binding="{Binding BankName}" 
                                                    Width="100"/>
                                <DataGridTextColumn Header="Number of an account" 
                                                    Binding="{Binding Number}" 
                                                    Width="*"/>
                                <DataGridTextColumn Header="Balance" 
                                                    Binding="{Binding Balance}" 
                                                    Width="80"/>
                                <DataGridCheckBoxColumn Header="Blocked" 
                                                        Binding="{Binding IsBlocked}" 
                                                        IsReadOnly="True"/>
                            </DataGrid.Columns>
                        </DataGrid>
                        <StackPanel Grid.Row="1" 
                                    Orientation="Horizontal" 
                                    HorizontalAlignment="Right">
                            <Button Content="Open an account" 
                                    Margin="5" 
                                    Padding="10,5" 
                                    Click="OpenAccount_Click"/>
                            <Button Content="Close account" 
                                    Margin="5" 
                                    Padding="10,5" 
                                    Click="CloseAccount_Click" 
                                    Background="#FFC1C1"/>
                            <Button Content="Deposite" 
                                    Margin="5" 
                                    Padding="10,5" 
                                    Click="DepositeAccount_Click"/>
                            <Button Content="Transfer" 
                                    Margin="5" 
                                    Padding="10,5" 
                                    Click="Transfer_Click"/>
                            <Button Content="History" 
                                    Margin="5" 
                                    Padding="10,5" 
                                    Click="History_Click"/>
                        </StackPanel>
                    </Grid>
                </TabItem>
                <TabItem Header="My deposits">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <DataGrid x:Name="ClientDepositsGrid" 
                                  AutoGenerateColumns="False" 
                                  CanUserAddRows="False">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Bank" 
                                                    Binding="{Binding BankName}" 
                                                    Width="100"/>
                                <DataGridTextColumn Header="Number of a deposit" 
                                                    Binding="{Binding Number}" 
                                                    Width="*"/>
                                <DataGridTextColumn Header="Balance" 
                                                    Binding="{Binding Balance}" 
                                                    Width="80"/>
                                <DataGridTextColumn Header="Procent" 
                                                    Binding="{Binding InterestRate}" 
                                                    Width="80"/>
                                <DataGridTextColumn Header="Term (mo)" 
                                                    Binding="{Binding TermMonths}" 
                                                    Width="80"/>
                                <DataGridTextColumn Header="Finish Date" 
                                                    Binding="{Binding EndDate, StringFormat=\{0:HH:mm:ss\}}" 
                                                    Width="100"/>
                                <DataGridCheckBoxColumn Header="Blocked" 
                                                    Binding="{Binding IsBlocked}" 
                                                    IsReadOnly="True"/>
                                <DataGridTextColumn Header="Accrued Interest" 
                                                    Binding="{Binding CurrentInterest, StringFormat=\{0:C\}}" 
                                                    Width="120" 
                                                    Foreground="Green" 
                                                    FontWeight="Bold"/>

                            </DataGrid.Columns>
                        </DataGrid>

                        <StackPanel Grid.Row="1" 
                                    Orientation="Horizontal" 
                                    HorizontalAlignment="Right">
                            <Button Content="Open a deposite" 
                                    Margin="5" 
                                    Padding="10,5" 
                                    Click="OpenDeposite_Click"/>
                            <Button Content="Transfer" 
                                    Margin="5" 
                                    Padding="10,5" 
                                    Click="TransferDeposit_Click"/>
                        </StackPanel>

                    </Grid>
                </TabItem>
                <TabItem Header="Enterprises">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <ListBox x:Name="EnterprisesListBox" 
                                 Margin="10">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" 
                                                Margin="5">
                                        <TextBlock Text="{Binding Name}" FontSize="16" Width="200"/>
                                        <TextBlock x:Name="StatusLabel" Foreground="Blue" FontStyle="Italic"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                        <StackPanel Grid.Row="1" 
                                    Orientation="Horizontal" 
                                    HorizontalAlignment="Right">
                            <Button Content="Apply for Salary Project" 
                                    Margin="5" Padding="10,5" 
                                    Click="ApplyForSalary_Click"/>
                            <Button x:Name="GetSalaryButton" 
                                    Content="GET SALARY" 
                                    Margin="5" 
                                    Padding="10,5" 
                                    Click="GetSalary_Click" 
                                    FontWeight="Bold" 
                                    Background="Gold" 
                                    Visibility="Collapsed"/>
                        </StackPanel>
                    </Grid>
                </TabItem>

            </TabControl>

        </GroupBox>
    </Grid>
</Window>

