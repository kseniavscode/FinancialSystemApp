<Window x:Class="LR1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:LR1"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <StackPanel Grid.Column="0" Margin="0,0,10,0">
            <TextBlock x:Name="WelcomeTextBlock" 
                       FontSize="16" 
                       FontWeight="Bold" 
                       TextWrapping="Wrap" 
                       Margin="0,0,0,20"/>
            <Button Content="Exit"
                    Padding="5"
                    Click="LogoutButton_Click"
                    Margin="30,10"
                    Background="#0078D7" 
                    Foreground="White" 
                    FontFamily="Gabriola"
                    FontSize="16"
                    FontWeight="DemiBold"/>
        </StackPanel>
        <GroupBox x:Name="AdminPanel" 
                  Grid.Column="1" 
                  Header="Admin panel" 
                  Visibility="Collapsed">
            <Grid >
         
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <StackPanel Orientation="Horizontal"
                            Grid.Row="0"
                            Margin="10">
                    <Button x:Name="ShowUsersListButton"
                            Content="Users list"
                            Margin="5"
                            Padding="5,1"
                            Background="#0078D7" 
                            Foreground="White" 
                            FontFamily="Gabriola"
                            FontSize="16"
                            Click="ShowUsersListButton_Click"/>
                    <Button x:Name="ShowActionsButton"
                            Content="Actions"
                            Margin="5"
                            Padding="5,1"
                            Background="#0078D7" 
                            Foreground="White" 
                            FontFamily="Gabriola"
                            FontSize="16"
                            Click="ShowActionsButton_Click"/>
                </StackPanel>

                <ListBox x:Name="UsersListBox"
                             Grid.Row="1"
                             Margin="0,10"
                             Visibility="Collapsed">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding Name}" FontWeight="Bold" Width="100"/>
                                <TextBlock Text="{Binding Role}" Width="80"/>
                                <TextBlock Text="Status: "/>
                                <TextBlock Text="{Binding Status}"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
                <DataGrid x:Name="AdminGrid" 
                          AutoGenerateColumns="False" 
                          CanUserAddRows="False"
                          Visibility="Collapsed"
                          Grid.Row="1">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Login" 
                                            Binding="{Binding Name}" 
                                            Width="*"/>
                        <DataGridTextColumn Header="Status" 
                                            Binding="{Binding Status}" 
                                            Width="100"/>
                        <DataGridTemplateColumn Header="Action" 
                                                Width="120">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="Reset the status" Click="ResetStatus_Click" Background="Orange"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <Button Content="Add meneger" 
                        Grid.Row="2" 
                        Padding="5" 
                        HorizontalAlignment="Right" 
                        Margin="30,10"
                        Background="#0078D7" 
                        Foreground="White" 
                        FontFamily="Gabriola"
                        FontSize="16"
                        Click="AddManagerButton_Click"/>
            </Grid>
        </GroupBox>

        <GroupBox x:Name="ManagerPanel"
                  Grid.Column="1"
                  Margin="10"
                  Visibility="Collapsed">
            <DataGrid x:Name="ManagerGrid"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False" SelectionChanged="ManagerGrid_SelectionChanged">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Login"
                                        Binding="{Binding Name}"
                                        Width="*"/>
                    <DataGridTemplateColumn Header="Actions"
                                            Width="180">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <Button x:Name="ApprovedButton" Content="Approve" Background="DarkSlateGray" Click="Approve_Click"/>
                                    <Button x:Name="RejectedButton" Content="Reject" Background="DarkRed" Click="Reject_Click"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                        
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
                
            </DataGrid>
            
        </GroupBox>
    </Grid>
</Window>
