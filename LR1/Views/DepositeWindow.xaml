<Window x:Class="LR1.Views.DepositeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:LR1.Views"
        mc:Ignorable="d"
        Title="DepositeWindow" Height="300" Width="400" WindowStartupLocation="CenterScreen">
    <Grid>
        <StackPanel Margin="20">
            <TextBlock Text="==== DEPOSITE" FontSize="18" Margin="20, 10" FontFamily="Artifakt Element" FontWeight="Bold"/>
            <TextBlock Text="Select the account" Margin="20,5" FontSize="14"/>
            <ComboBox x:Name="DepositeComboBox" DisplayMemberPath="DisplayInfo" Margin="20, 5" Padding="10"/>
            <TextBlock Text="Enter the sum" Margin="20,5" FontSize="14"/>
            <TextBox x:Name="SumDepositeTextBox" Margin="20, 5" Padding="5"/>
            <Button Content="DEPOSITE" 
        Click="DepositeButton_Click"
        FontSize="16"
        Background="CornflowerBlue" 
        Foreground="White" 
        Margin="40,5"
        Padding="5"
        FontFamily="Arial Black"
        FontWeight="Bold"/>
        </StackPanel>
    </Grid>
</Window>
