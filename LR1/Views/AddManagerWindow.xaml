<Window x:Class="LR1.Views.AddManagerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:LR1.Views"
        mc:Ignorable="d"
        Title="AddManagerWindow" Height="300" Width="350" WindowStartupLocation="CenterOwner">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="NEW MANAGER" 
           FontSize="18" 
           FontWeight="Bold" 
           FontFamily="Arial Black" 
           HorizontalAlignment="Left" 
           Margin="10,0,0,10" 
           Grid.Row="0"/>
        <TextBlock Text="Login:" 
           FontSize="18" 
           FontWeight="DemiBold" 
           FontFamily="Book Antiqua" 
           HorizontalAlignment="Left" 
           Margin="20,10,0,5" 
           Grid.Row="1"/>
        <TextBox x:Name="LoginManagerTextBox" 
         Grid.Row="2" 
         Margin="15,5,15,5" 
         Padding="5"/>
        <TextBlock Text="Password:" 
           FontSize="18" 
           FontWeight="DemiBold" 
           FontFamily="Book Antiqua" 
           HorizontalAlignment="Left" 
           Margin="20,5,0,5" 
           Grid.Row="3"/>
        <TextBox x:Name="PasswordManagerTextBox" 
             Grid.Row="4" 
             Margin="15,5,15,5" 
             Padding="5"/>
        <Button x:Name="ManagerButton" 
        Content="CREATE" 
        Background="#28A745" 
        Foreground="White" 
        FontFamily="Gabriola" 
        FontSize="16" 
        Padding="2" 
        FontWeight="DemiBold" 
        Grid.Row="5" 
        Margin="60,10" 
        Click="CreateManagerButton_Click"/>
    </Grid>
</Window>
