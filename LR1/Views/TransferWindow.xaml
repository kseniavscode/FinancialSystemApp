<Window x:Class="LR1.Views.TransferWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:LR1.Views"
        mc:Ignorable="d"
        Title="TransferWindow" Height="450" Width="800" WindowStartupLocation="CenterOwner">
    <Grid>
        <StackPanel Margin="20">
            <TextBlock Text="==== TRANSFER" FontSize="20" Margin="40, 20" FontFamily="Artifakt Element" FontWeight="Bold"/>
            <TextBlock Text="Select the account from which the transfer will be made" Margin="20,5" FontSize="16"/>
            <ComboBox x:Name="FromAccountComboBox" DisplayMemberPath="DisplayInfo" Margin="20, 5" Padding="10"/>
            <TextBlock Text="Enter the account`s number to which the transfer will be made (BY******)" Margin="20,5" FontSize="16"/>
            <TextBox x:Name="ToAccountNumberTextBox" Margin="20, 5" Padding="5"/>
            <TextBlock Text="Enter the sum of the transfer" Margin="20,5" FontSize="16"/>
            <TextBox x:Name="SumTransferTextBox" Margin="20, 5" Padding="5"/>
            <Button Content="TRANSFER" 
                Click="TransferButton_Click"
                FontSize="19"
                Background="Green" 
                Foreground="White" 
                Margin="150,40" 
                Padding="10" 
                FontFamily="Arial Black"
                FontWeight="Bold"/>
        </StackPanel>
    </Grid>
</Window>
