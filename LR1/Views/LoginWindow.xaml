<Window x:Class="LR1.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:LR1.Views"
        mc:Ignorable="d"
        Title="LoginWindow" Height="350" Width="350" WindowStartupLocation="CenterScreen">
    <Grid Margin="20" >
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="ENTERING IN SYSTEM" 
                   FontSize="20" 
                   FontWeight="Bold" 
                   FontFamily="Arial Black" 
                   HorizontalAlignment="Center" 
                   Margin="0,0,0,10" 
                   Grid.Row="0"/>
        <TextBlock Text="Login:" 
                   FontSize="18" 
                   FontWeight="DemiBold" 
                   FontFamily="Book Antiqua" 
                   HorizontalAlignment="Left" 
                   Margin="20,10,0,5" 
                   Grid.Row="1"/>
        <TextBox x:Name="LoginTextBox" 
                 Grid.Row="2" 
                 Margin="15,5,15,5" 
                 Padding="5"/>
        <TextBlock Text="Password:" 
                   FontSize="18" 
                   FontWeight="DemiBold" 
                   FontFamily="Book Antiqua" 
                   HorizontalAlignment="Left" 
                   Margin="20,5,0,5" 
                   Grid.Row="3"/>
        <PasswordBox x:Name="PasswordTextBox" 
                     Grid.Row="4" 
                     Margin="15,5,15,5" 
                     Padding="5"/>
        <Button x:Name="RegistrationButton" 
                Content="registration" 
                Background="white" 
                Foreground="gray" 
                FontFamily="Gabriola" 
                FontSize="16" 
                Padding="0" 
                FontWeight="DemiBold" 
                Grid.Row="5" 
                Margin="90,10,90,0" 
                Click="RegistrationButton_Click"/> 
        <Button x:Name="LoginButton" 
                Content="ENTER" 
                Background="#0078D7" 
                Foreground="White" 
                FontFamily="Gabriola" 
                FontSize="16" 
                Padding="2" 
                FontWeight="DemiBold" 
                Grid.Row="6" 
                Margin="60,10" 
                Click="LoginButton_Click"/>
    </Grid>
</Window>
