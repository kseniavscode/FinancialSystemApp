<Window x:Class="LR1.Views.AddDepositWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:LR1.Views"
        mc:Ignorable="d"
        Title="AddDepositWindow" Height="450" Width="450" WindowStartupLocation="CenterOwner">
    <Grid x:Name="OpenDepositGrid">
        <StackPanel Margin="20">
            <TextBlock Text="Open a deposit" FontSize="18" Margin="20, 10" FontFamily="Artifakt Element" FontWeight="Bold"/>
            <TextBlock Text="Select source account:" Margin="20,5"/>
            <ComboBox x:Name="SourceAccountComboBox" DisplayMemberPath="Number" Margin="20,5" Padding="5"/>
            <TextBlock Text="Enter amount to deposit ($$S$$):" Margin="20,5"/>
            <TextBox x:Name="AmountTextBox" Margin="20,5" Padding="5"/>
            <TextBlock Text="Enter an interest rate (%)" Margin="20,5" FontSize="14"/>
            <TextBox x:Name="InterestRateTextBox" Margin="20, 5" Padding="5"/>
            <TextBlock Text="Enter the term (months)" Margin="20,5" FontSize="14"/>
            <TextBox x:Name="TermDepositeTextBox" Margin="20, 5" Padding="5"/>
            <Button Content="Open a deposite" 
                    Click="OpenDepositButton_Click"
                    FontSize="16"
                    Background="DarkSeaGreen" 
                    Foreground="White" 
                    Margin="40,5"
                    Padding="5"
                    FontFamily="Arial Black"
                    FontWeight="Bold"/> 
        </StackPanel>

    </Grid>
</Window>
